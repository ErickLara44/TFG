# syntax=docker/dockerfile:1

# --- Builder stage: install dependencies ---
FROM python:3.12-slim AS builder

# Set workdir for builder
WORKDIR /app

# Copy only dependency files first for caching
COPY --link pyproject.toml setup.cfg ./

# Install build dependencies
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --upgrade pip && \
    pip install flit

# Install project dependencies (editable mode for src)
RUN --mount=type=cache,target=/root/.cache/pip \
    flit install --deps production --symlink

# --- Final stage: runtime image ---
FROM python:3.12-slim AS final

# Create non-root user
RUN useradd -m appuser
USER appuser

WORKDIR /app

# Copy installed site-packages from builder
COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages

# Copy source code (src) into image
COPY --link . ./

# Set default entrypoint (can be overridden)
CMD ["python"]

# --- Notes ---
# - .dockerignore should exclude .env, .git*, .DS_Store, notebooks, data, outputs, reports, .venv, and any secrets.
# - Pass runtime environment variables via docker run -e or Docker Compose.
# - For running a specific module, override CMD as needed, e.g.:
#   CMD ["python", "-m", "src.FWI_baseline"]
